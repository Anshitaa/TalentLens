# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=talentlens
POSTGRES_USER=talentlens
POSTGRES_PASSWORD=talentlens
DATABASE_URL=postgresql://talentlens:talentlens@localhost:5434/talentlens
# Note: the postgres service in docker-compose uses POSTGRES_USER=talentlens directly,
# so Docker auto-creates the user + database. No manual role creation needed.

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_RISK_ENGINE=risk-engine-consumer
KAFKA_CONSUMER_GROUP_DASHBOARD=dashboard-consumer
KAFKA_CONSUMER_GROUP_AUDIT=audit-consumer

# Airflow
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# LLM Providers (Phase 5)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_HOST=http://localhost:11434

# AWS (Phase 7)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=talentlens-data

# Slack (Phase 6)
SLACK_WEBHOOK_URL=

# MLflow (Phase 3)
MLFLOW_TRACKING_URI=http://localhost:5001

# Synthetic Generator
GENERATOR_SEED=42
GENERATOR_N_EMPLOYEES=85000
GENERATOR_SIM_START=2024-01-01
GENERATOR_SIM_END=2025-12-31
